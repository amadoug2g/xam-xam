[Unit]
Description=Xam-Xam API (FastAPI backend for Wolof learning app)
After=network.target

[Service]
Type=simple
User=claudeuser
Group=claudeuser
WorkingDirectory=/home/claudeuser/xam-xam/scripts/api
ExecStart=/usr/bin/python3 -m uvicorn main:app --host 0.0.0.0 --port 8787 --log-level info
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
